    {
      "parameters": {
        "jsCode": "const source = $node['Normalizar entrada'].json;\nconst response = $node['Supabase - buscar contato'].json;\nconst customers = Array.isArray(response) ? response : (response.body || []);\nconst customer = customers[0] || {};\nconst texto = String(source.texto || '').toLowerCase();\nconst status = String(customer.status || 'new');\nconst initialNotSent = !customer.status || status === 'new' || status === 'bot';\nlet route = 'ai_reply';\n\nif (status === 'human_takeover') route = 'human_paused';\nelse if (status === 'waiting_test_confirmation' && /\\b(sim|pode|agora|ok|claro)\\b/i.test(texto)) route = 'request_arthur_approval';\nelse if (initialNotSent) route = 'initial_flow';\nelse if (/\\b(teste|testar|demo|acesso)\\b/i.test(texto)) route = 'ask_test_time';\nelse if (/\\b(valor|preco|pre?o|plano|planos|quanto|mensal|mensalidade)\\b/i.test(texto)) route = 'send_prices';\n\nreturn [{ json: { ...source, customer, route } }];"
      },
