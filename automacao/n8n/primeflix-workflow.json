    {
      "parameters": {
        "jsCode": "const source = $node['Normalizar entrada'].json;\nconst contacts = Array.isArray($json) ? $json : ($json.body || []);\nconst contact = contacts[0] || null;\nconst text = String(source.text || '').toLowerCase();\nconst takeoverUntil = contact?.human_takeover_until ? new Date(contact.human_takeover_until) : null;\nlet route = 'ai_reply';\nif (!contact || !contact.initial_flow_sent_at) route = 'initial_flow';\nelse if (takeoverUntil && takeoverUntil > new Date()) route = 'human_paused';\nelse if (contact.state === 'waiting_test_confirmation' && /\\b(sim|pode|agora|ok|claro)\\b/i.test(text)) route = 'request_arthur_approval';\nelse if (/\\b(teste|testar|demo|acesso)\\b/i.test(text)) route = 'ask_test_time';\nelse if (/\\b(valor|preco|preco|plano|planos|quanto|mensal|mensalidade)\\b/i.test(text)) route = 'send_prices';\nreturn [{ json: { ...source, contact, route } }];"
      },
