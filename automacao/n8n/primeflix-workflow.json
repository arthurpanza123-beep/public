    {
      "parameters": {
        "jsCode": "const body = $json.body || $json;\nconst phone = String(body.phone || body.from || '').replace(/\\D/g, '');\nconst text = String(body.message?.text || body.text || '').trim();\nif (!phone) throw new Error('Mensagem sem telefone normalizado.');\nreturn [{ json: {\n  phone,\n  jid: body.jid || '',\n  pushName: body.pushName || '',\n  text,\n  messageType: body.message?.type || 'text',\n  messageId: body.messageId || '',\n  receivedAt: new Date().toISOString()\n}}];"
      },
      "id": "normalize-incoming",
      "name": "Normalizar entrada",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1660,
        0
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{$env.SUPABASE_URL}}/rest/v1/contacts?phone=eq.{{$json.phone}}&select=*",
