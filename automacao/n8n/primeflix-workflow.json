    {
      "parameters": {
        "jsCode": "const source = $json.body || $json;\nconst cleanPhone = (value) => String(value || '')\n  .replace('@s.whatsapp.net', '')\n  .replace('@lid', '')\n  .replace(/\\D/g, '');\n\nconst telefone = cleanPhone(source.phone)\n  || cleanPhone(source.raw?.key?.senderPn)\n  || cleanPhone(source.jid);\n\nif (!telefone) throw new Error('Mensagem sem telefone normalizado.');\n\nconst Texto = source.Texto || '';\n\nreturn [{ json: {\n  telefone,\n  jid: source.jid || '',\n  pushName: source.pushName || 'Cliente',\n  Texto,\n  texto: Texto,\n  text: Texto,\n  messageType: source.message?.type || 'text',\n  messageId: source.messageId || ''\n}}];"
      },
      "id": "normalize-incoming",
      "name": "Normalizar entrada",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1660,
        0
      ]
    },
