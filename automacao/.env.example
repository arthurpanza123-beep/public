# =========================
# PRIMEFLIX BOT - ENV
# =========================

# Ambiente
# Use development na maquina local e production na VPS.
NODE_ENV=development

# Porta HTTP do bot/API Node.js que recebe comandos do n8n.
PORT=3333

# URL publica do bot/API Node.js.
# Localmente, use http://localhost:3333. Na VPS, use o dominio publico se o n8n chamar por fora.
BOT_PUBLIC_URL=http://localhost:3333

# URL do webhook do n8n que recebe mensagens do WhatsApp.
# Depois de importar e ativar o workflow, copie a URL de producao do webhook de entrada.
N8N_WEBHOOK_URL=https://SEU_N8N/webhook/whatsapp-incoming

# Supabase
# URL e anon key publicas do projeto Primeflix.
SUPABASE_URL=https://woonzezkmbsnczwhcaic.supabase.co
SUPABASE_ANON_KEY=sb_publishable_wDoc5iO-s_iSzjqd5NzoLw_GuQ-IC0a

# Service role privada do Supabase.
# Nunca coloque essa chave no frontend, no Lovable publico, no GitHub ou no workflow exportado.
SUPABASE_SERVICE_KEY=COLE_AQUI_SUA_SERVICE_ROLE_KEY_NOVA

# KIE AI / Claude Haiku
# Chave privada da KIE AI e modelo usado pelo atendimento.
KIE_API_KEY=COLE_AQUI_SUA_KIE_API_KEY
KIE_MODEL=claude-haiku-4-5

# Arthur / operador humano
# Telefone com DDI e DDD, somente numeros. Exemplo: 5511999999999.
ARTHUR_PHONE=55DDDNUMERO
ARTHUR_NAME=Arthur

# WhatsApp
# Pasta onde a sessao do WhatsApp sera salva e nome visivel do navegador pareado.
WHATSAPP_SESSION_DIR=./sessions
WHATSAPP_BOT_NAME=Primeflix Bot

# Materiais oficiais
# A pasta material deve conter exatamente estes arquivos oficiais.
MATERIAL_DIR=./material
AUDIO_01=apresentacao01.ogg
AUDIO_02=apresentacao02.ogg
AUDIO_03=qualatv.ogg
AUDIO_RENOVACAO=renovacao.ogg
IMAGE_FEEDBACKS=feedbaks.jpeg
IMAGE_VALORES=valor.jpeg
IMAGE_BLACK=black.jpeg

# Presenca/animacoes
# Tempos usados para simular digitando e gravando audio.
TYPING_DELAY_SECONDS=3
RECORDING_DELAY_SECONDS=6
USE_RANDOM_DELAYS=true

# Painel externo para criar teste via Playwright
# URL, usuario e senha do painel externo onde o teste de 1 hora e criado.
TEST_PANEL_URL=COLE_AQUI_URL_DO_PAINEL
TEST_PANEL_USER=COLE_AQUI_USUARIO
TEST_PANEL_PASSWORD=COLE_AQUI_SENHA
TEST_DEFAULT_DURATION_HOURS=1

# Regras de teste
# Provedor padrao salvo/enviado quando o painel nao exibir provedor.
TEST_PROVIDER=primeflixapp
TEST_REQUIRE_CLIENT_CONFIRMATION=true
TEST_REQUIRE_ARTHUR_APPROVAL=true

# Seguranca
# Se faltar provedor quando existir, usuario, senha ou vencimento, o bot nao envia teste ao cliente.
NEVER_SEND_TEST_IF_MISSING_FIELDS=true
LOG_LEVEL=info
